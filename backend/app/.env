# PostgreSQL Connection (Async)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/hitl_db
SQLALCHEMY_ECHO=false

# MongoDB Connection
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=hitl_grading

# JWT Authentication
JWT_SECRET_KEY=your-super-secret-key-for-development-change-this-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
